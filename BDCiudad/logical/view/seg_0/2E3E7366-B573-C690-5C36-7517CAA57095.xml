<userDefinedSQL><![CDATA[SELECT Barrio.*,
  Familias.*,
  Instituciones.*,
  Integrantes.*
FROM Barrio
  INNER JOIN Familias ON Barrio.codBarrio = Familias.codBarrio
  INNER JOIN Integrantes ON Familias.codFamilia = Integrantes.codFamilia,
  Instituciones]]></userDefinedSQL>
